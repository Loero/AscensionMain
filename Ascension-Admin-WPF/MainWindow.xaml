<Window x:Class="Ascension.Admin.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ascension Admin"
        Height="720"
        Width="1180"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Padding="12" Margin="0,0,0,12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="API base URL" FontWeight="SemiBold" Margin="0,0,0,4" />
          <TextBox x:Name="BaseUrlTextBox" Text="http://localhost:3000" Padding="8" />
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0,0,10,0">
          <TextBlock Text="Admin username" FontWeight="SemiBold" Margin="0,0,0,4" />
          <TextBox x:Name="UsernameTextBox" Text="admin" Padding="8" />
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="0,0,10,0">
          <TextBlock Text="Admin password" FontWeight="SemiBold" Margin="0,0,0,4" />
          <PasswordBox x:Name="PasswordBox" Padding="8" />
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
          <Button x:Name="LoginButton"
                  Width="130"
                  Height="36"
                  Content="Login"
                  Click="LoginButton_Click" />
        </StackPanel>

        <TextBlock Grid.Column="4"
                   x:Name="LoginStateTextBlock"
                   VerticalAlignment="Center"
                   Margin="16,0,0,0"
                   FontWeight="SemiBold"
                   Foreground="#666"
                   Text="Nincs bejelentkezve" />
      </Grid>
    </Border>

    <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,12">
      <Border Margin="0,0,8,0" Padding="10" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6">
        <StackPanel>
          <TextBlock Text="Users" Foreground="#666" />
          <TextBlock x:Name="UsersCountText" Text="0" FontSize="24" FontWeight="Bold" />
        </StackPanel>
      </Border>

      <Border Margin="0,0,8,0" Padding="10" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6">
        <StackPanel>
          <TextBlock Text="Food entries" Foreground="#666" />
          <TextBlock x:Name="FoodEntriesCountText" Text="0" FontSize="24" FontWeight="Bold" />
        </StackPanel>
      </Border>

      <Border Margin="0,0,8,0" Padding="10" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6">
        <StackPanel>
          <TextBlock Text="Workout entries" Foreground="#666" />
          <TextBlock x:Name="WorkoutEntriesCountText" Text="0" FontSize="24" FontWeight="Bold" />
        </StackPanel>
      </Border>

      <Border Margin="0,0,8,0" Padding="10" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6">
        <StackPanel>
          <TextBlock Text="Skin routines" Foreground="#666" />
          <TextBlock x:Name="SkinRoutinesCountText" Text="0" FontSize="24" FontWeight="Bold" />
        </StackPanel>
      </Border>

      <Border Margin="0,0,8,0" Padding="10" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6">
        <StackPanel>
          <TextBlock Text="Food calories" Foreground="#666" />
          <TextBlock x:Name="FoodCaloriesText" Text="0" FontSize="24" FontWeight="Bold" />
        </StackPanel>
      </Border>

      <Border Padding="10" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6">
        <StackPanel>
          <TextBlock Text="Burned calories" Foreground="#666" />
          <TextBlock x:Name="BurnedCaloriesText" Text="0" FontSize="24" FontWeight="Bold" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <Border Grid.Row="2" BorderThickness="1" BorderBrush="#DDD" CornerRadius="8">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10">
          <Button x:Name="RefreshButton"
                  Width="120"
                  Height="34"
                  Margin="0,0,8,0"
                  Content="Frissites"
                  Click="RefreshButton_Click"
                  IsEnabled="False" />
          <Button x:Name="DeleteButton"
                  Width="160"
                  Height="34"
                  Content="Kijelolt torlese"
                  Click="DeleteButton_Click"
                  IsEnabled="False" />
        </StackPanel>

        <DataGrid x:Name="UsersGrid"
                  Margin="10,0,10,10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="UsersGrid_SelectionChanged">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="130" />
            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220" />
            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt}" Width="160" />
            <DataGridTextColumn Header="Food entries" Binding="{Binding FoodEntries}" Width="100" />
            <DataGridTextColumn Header="Workout entries" Binding="{Binding WorkoutEntries}" Width="110" />
            <DataGridTextColumn Header="Skin routines" Binding="{Binding SkinRoutines}" Width="100" />
            <DataGridTextColumn Header="Food kcal" Binding="{Binding TotalFoodCalories}" Width="100" />
            <DataGridTextColumn Header="Burned kcal" Binding="{Binding TotalBurnedCalories}" Width="100" />
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Border>

    <TextBlock Grid.Row="3"
               x:Name="MessageTextBlock"
               Margin="0,12,0,0"
               Foreground="#444"
               TextWrapping="Wrap"
               Text="Kezdeshez jelentkezz be admin userrel." />
  </Grid>
</Window>
